# 生产环境变量（部署到 Vercel 时需要配置）

## ========== DashScope 配置 ==========
# 从阿里云 DashScope 控制台获取
# https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# Embedding 模型（固定）
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3

# 大模型选择
# 可选: qwen-max (最强但慢) | qwen-plus (推荐) | qwen-turbo (最快)
DASHSCOPE_CHAT_MODEL=qwen-plus

## ========== Pinecone 配置 ==========
# 从 Pinecone 控制台获取
# https://www.pinecone.io/
PINECONE_API_KEY=pk-your-pinecone-key-here

# Pinecone 索引名称（需要自己在 Pinecone 创建）
# 创建时的维度必须设为 768（与 text-embedding-v3 一致）
PINECONE_INDEX_NAME=luv-blog

## ========== Vercel 定时任务 ==========
# 用于验证定时任务请求的 Token
# 生成一个强密码，然后在定时任务（cron-job.org）中使用
CRON_SECRET=your-super-secret-token-12345

## ========== GitHub 配置（可选） ==========
# 如果 articles.js 获取失败，可以显式设置 GitHub 仓库 URL
# GITHUB_REPO_URL=https://raw.githubusercontent.com/你的用户名/你的仓库/main/src/data/articles.js

## ========== 本地开发 ==========
# .env.local 文件（不提交到 Git）
# 本地测试时可以设置：
# VITE_API_BASE=http://localhost:3000
